<file path="styles/_menus.scss">
@use "vars" as *;
// === ДИСКЛЕЙМЕР (INTRO SCREEN) ===

#disclaimer-screen {
  position: fixed;
  inset: 0;
  z-index: 99999; // Поверх вообще всего во вселенной!
  background: #000;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #fff;
  font-family: "Inter", sans-serif;
  transition: opacity 1s ease-in-out; // Плавное затухание при клике

  &.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .disclaimer-content {
    text-align: center;
    max-width: 800px;
    padding: 20px;
  }

  // Заголовок "ВНИМАНИЕ!"
  #disclaimer-title {
    font-family: "Inter", sans-serif; // Более технический шрифт
    font-weight: 900; // Максимально жирный
    font-size: 6rem; // Огромный!
    letter-spacing: 25px;
    margin-bottom: 40px;
    position: relative;
    display: inline-block;
    text-transform: uppercase;

    // ЭФФЕКТ ГОЛОГРАФИЧЕСКИХ ПОЛОС
    color: transparent; // Прячем обычный цвет
    background: repeating-linear-gradient(
      0deg,
      #00ffff 0px,
      #00ffff 4px,
      // Толщина светящейся линии
      transparent 4px,
      transparent 8px // Толщина пустой (темной) линии
    );
    -webkit-background-clip: text;
    background-clip: text;

    // Легкое свечение вокруг букв
    filter: drop-shadow(0 0 15px rgba(0, 255, 255, 0.6));

    // Вспышка и исчезновение (резкий цифровой сбой)
    animation: flashOut 0.15s cubic-bezier(0.1, 0.9, 0.2, 1) 0.8s forwards;

    .typewriter-burst {
      display: inline-block;
      overflow: hidden;
      white-space: nowrap;
      border-right: 12px solid #00ffff; // Синяя толстая каретка терминала
      width: 0;

      // Печать за 0.25с (еще быстрее!)
      animation:
        burstType 0.25s steps(9, end) forwards,
        blinkCaret 0.08s step-end infinite;
    }
  }

  // Основной текст (резко бьет по глазам после вспышки)
  #disclaimer-body {
    opacity: 0;
    transform: scale(1.1); // Слегка увеличен
    filter: blur(10px); // Размыт
    // Резко фокусируется через 0.9с (сразу после вспышки заголовка)
    animation: slamDown 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) 0.9s
      forwards;

    p {
      font-size: 1.2rem;
      line-height: 1.8;
      color: rgba(255, 255, 255, 0.9);
      margin-bottom: 15px;
    }

    .click-to-continue {
      margin-top: 50px;
      font-size: 1rem;
      color: #00ffff;
      letter-spacing: 4px;
      animation: pulseText 1.5s infinite ease-in-out 0.5s;
    }
  }
}

#splash-screen {
  position: absolute;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background-color: #000;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99998; /* Чуть ниже дисклеймера */
  opacity: 0;
  pointer-events: none;
  transition: opacity 1s ease-in-out;

  h1 {
    font-size: 1.5rem;
    font-weight: 300;
    letter-spacing: 0.8rem;
    text-transform: uppercase;
    color: #ffffff;
    text-shadow: 0 0 10px rgba(255, 255, 255, 0.3);
  }
}

// === ГЛАВНОЕ МЕНЮ ===
#main-menu-screen {
  /* Запираем видео в 16:9 */
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100vw;
  height: 100vh;
  max-width: calc(100vh * (16 / 9));
  aspect-ratio: 16 / 9;

  display: flex;
  justify-content: flex-start; /* Прижимаем контент влево */
  align-items: center;
  overflow: hidden;
  z-index: 10;
  background-color: #000;
  box-shadow: 0 0 100px 30px rgba(0, 0, 0, 0.95);

  .menu-bg-video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: -1;
    pointer-events: none;
    filter: brightness(0.6); /* Слегка гасим фон, чтобы кнопки читались лучше */
  }

  /* МАЙ: Случайный персонаж в главном меню */
  .sota-menu-character {
    position: absolute;
    right: 5%; /* Отступ от правого края */
    bottom: -5%; /* Немного опускаем спрайт вниз, чтобы он выглядел естественно */
