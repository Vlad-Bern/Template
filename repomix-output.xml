    color: rgba(255, 255, 255, 0.6);
    font-family: "Inter", sans-serif;
    font-size: 14px;
    letter-spacing: 2px;
    pointer-events: none;
  }
}

// ✅ Правильный порядок
.version-watermark {
  // Сначала — десктопные стили (base)
  position: absolute;
  bottom: 0;
  right: 0;
  z-index: 1000;
  padding: 40px 30px 10px 50px;
  background: radial-gradient(
    100% 100% at 100% 100%,
    rgba(0, 0, 0, 0.8) 0%,
    rgba(0, 0, 0, 0) 100%
  );
  color: rgba(255, 255, 255, 0.45);
  font-family: "Inter", sans-serif;
  font-size: 13px;
