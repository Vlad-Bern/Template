    width: auto;
    z-index: 2; /* Между фоном и кнопками */
    pointer-events: none; /* Чтобы спрайт не мешал кликать, если случайно перекроет что-то */
    mask-image: linear-gradient(to top, transparent 0%, black 10%);

    img {
      height: 100%;
      width: auto;
      object-fit: contain;
      filter: drop-shadow(
        -10px 10px 20px rgba(0, 0, 0, 0.8)
      ); /* Красивая тень */
      opacity: 0; /* Изначально прозрачный для плавной анимации */
      transform: translateX(30px); /* Слегка сдвинут вправо */
      transition:
        opacity 1.5s ease-in-out,
        transform 1.5s ease-out; /* Плавное появление */

      &.visible {
        opacity: 1;
        transform: translateX(0);
      }
    }
  }

  .menu-buttons-container {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 30px;
    margin-left: 10%;

    button {
      background: transparent;
      border: none;
      cursor: pointer;
      text-align: left;
      padding: 10px 0;
      width: 100%;
      max-width: 400px;

      .visual {
        display: inline-block;
        color: rgba(255, 255, 255, 0.6);
        font-family: "Inter", sans-serif;
        font-size: 2rem;
        font-weight: 300;
        letter-spacing: 5px;
        text-transform: uppercase;
        position: relative;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);

        &::after {
          content: "";
          position: absolute;
          bottom: -5px;
          left: 0;
          width: 0%;
          height: 2px;
          background: $ui-accent;
          transition: width 0.3s ease;
          box-shadow: 0 0 10px rgba($ui-accent, 0.8);
        }
      }

      // === HOVER ТОЛЬКО ДЛЯ МЫШИ! НА ТАЧСКРИНАХ НЕ ЗАЛИПАЕТ ===
      @media (hover: hover) and (pointer: fine) {
        &:hover .visual {
          color: #fff;
          text-shadow: 0 0 15px rgba($ui-accent, 0.6);
          transform: translateX(20px);

          &::after {
            width: 100%;
          }
        }
      }

      // === ВДАВЛИВАНИЕ ПРИ ТАПЕ (ВМЕСТО HOVER) ===
      &:active .visual {
        color: #fff;
        transform: scale(0.97);
      }

      /* Стили для красной кнопки выхода */
      &#btn-exit {
        margin-top: 50px;

        .visual {
          font-size: 1.5rem;
          &::after {
            background: rgba(150, 0, 0, 0.8);
            box-shadow: 0 0 10px rgba(150, 0, 0, 0.8);
          }
        }

        &:hover .visual {
          color: #ff4d4d;
          text-shadow: 0 0 15px rgba(150, 0, 0, 0.8);
        }
      }
    }
  }

  #menu-black-overlay {
    position: absolute;
    inset: 0;
    background: #000;
    z-index: 15;
  }

  #main-menu-title {
    position: absolute;
    top: 15%;
    left: 10%;
    z-index: 3;

    display: flex;
    flex-wrap: nowrap;
    gap: 20px;

    font-family: "Inter", sans-serif;
    text-transform: uppercase;

    // МАЙ: Чистая жесткая обводка для букв везде!
    -webkit-text-stroke: 1px rgba(0, 0, 0, 0.8);
    text-shadow: 0 0 15px rgba(0, 0, 0, 0.9);

    .word {
      display: flex;
      align-items: baseline;

      .initial {
        font-size: 5rem;
        font-weight: 300;
        color: #00ffff;
        // У первых букв обводка чуть толще
        -webkit-text-stroke: 2px rgba(0, 0, 0, 0.9);
        text-shadow: 0 0 20px rgba(0, 255, 255, 0.5);
      }
      .rest {
        font-size: 3rem;
        font-weight: 300;
        color: #ffffff;
      }
    }
  }

  .neon-letter-active {
    color: $ui-accent;
    animation: realistic-neon-flicker 5s infinite;
  }

  // Добавь это куда-нибудь в конец style.scss
  .version {
    position: absolute;
    bottom: 0;
    right: 0;
    z-index: 100; // Поверх персонажей
    padding: 30px 30px 15px 50px; // Большой отступ сверху и слева для плавного градиента
    background: radial-gradient(
      100% 100% at 100% 100%,
      rgba(0, 0, 0, 0.8) 0%,
      transparent 100%
