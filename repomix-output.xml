}

// === КНОПКИ СОЦСЕТЕЙ В ГЛАВНОМ МЕНЮ ===
#main-menu-socials {
  position: absolute;
  bottom: 40px;
  right: 2vw;
  display: flex;
  gap: 15px;
  z-index: 10;

  .menu-social-btn {
    @media (min-width: 768px) {
      width: 55px;
