@use "vars" as *;
/* === МАЙ: СТИЛИ ГАЛЕРЕИ (СИНСЮ ОС) === */

.sota-gallery-modal {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(5, 5, 5, 0.85); /* Очень темный фон */
  backdrop-filter: blur(8px); /* Красивое размытие задника */
  z-index: 10000;
  justify-content: center;
  align-items: center;
  font-family: "Courier New", monospace; /* Подставьте сюда ваш шрифт */
}

.sota-gallery-content {
  width: 85vw;
  height: 85vh;
  background: linear-gradient(180deg, #111 0%, #0a0a0c 100%);
  border: 1px solid #333;
  box-shadow:
    0 0 40px rgba(0, 0, 0, 0.9),
    inset 0 0 20px rgba(255, 255, 255, 0.02);
  display: flex;
  flex-direction: column;
  position: relative;
}

.sota-gallery-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 40px;
  border-bottom: 1px solid #222;
  background: rgba(0, 0, 0, 0.4);

  h2 {
    color: #e0e0e0;
    margin: 0;
    font-size: 1.4rem;
    letter-spacing: 3px;
    font-weight: normal;
  }
}

.sota-close-btn {
  background: transparent;
  border: none;
  color: #666;
  font-size: 2rem;
  cursor: pointer;
  line-height: 1;
  transition:
    color 0.2s,
    transform 0.2s;

  &:hover {
    color: #fff;
    transform: scale(1.1);
  }
}

.sota-gallery-grid {
  flex: 1;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 25px;
  padding: 40px;
  overflow-y: auto;
  align-content: start;

  // === МАЙ: ФИКС СВАЙПОВ В ГАЛЕРЕЕ ===
  // 1. Разрешаем браузеру скроллить только вверх-вниз (pan-y).
  // Горизонтальные свайпы браузер игнорирует и отдаёт нашему JavaScript!
  touch-action: pan-y;

  // 2. Отключаем "резиновую" прокрутку на iOS (чтобы не было bounce-эффекта)
  overscroll-behavior-y: contain;

  /* === Корпоративный кастомный скроллбар (Chrome/Safari/NW.js) === */
  &::-webkit-scrollbar {
    width: 6px;
  }
  &::-webkit-scrollbar-track {
    background: #050505;
    border-left: 1px solid #111;
  }
  &::-webkit-scrollbar-thumb {
    background: #444;
  }
  &::-webkit-scrollbar-thumb:hover {
    background: #777;
  }

  /* === МАЙ: Фикс жестов (чтобы картинки не цеплялись пальцем) === */
  img {
    -webkit-user-drag: none;
    -webkit-user-select: none;
    user-select: none;
  }
}

.sota-gallery-item {
  width: 100%;
  aspect-ratio: 16 / 9;
  object-fit: cover;
  border: 1px solid #222;
  cursor: pointer;

  /* Стерильность: обесцвечиваем и затемняем неактивные картинки */
  filter: grayscale(80%) brightness(0.6) contrast(1.2);
  transition: all 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);

  // === МАЙ: АППАРАТНОЕ УСКОРЕНИЕ (ОПТИМИЗАЦИЯ 4K) ===
  // Заставляем браузер отрендерить эту картинку как отдельный слой на GPU
  transform: translateZ(0);
  will-change:
    transform, filter; // Заранее говорим браузеру, что будет меняться
  // Чтобы сжатые 4K картинки не "шумели" и не жрали ресурсы на сглаживание:
  image-rendering: -webkit-optimize-contrast;

  &:hover {
    filter: grayscale(0%) brightness(1.1) contrast(1.1);
    box-shadow:
      0 0 30px rgba(0, 255, 255, 0.15),
      0 0 10px rgba(0, 255, 255, 0.3) inset;
    border-color: #00ffff;
    // Оставляем аппаратное ускорение и при увеличении
    transform: scale(1.05) translateZ(0);
    z-index: 10;
  }
}
