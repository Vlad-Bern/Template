<file path="styles/_titlebar.scss">
@use "vars" as *;

body.nw-app #game-container {
  padding-top: 36px;
}

#title-bar {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 36px;
  z-index: 99999;
  display: flex;
  align-items: stretch;
  background: rgba(6, 6, 8, 0.97);
  border-bottom: 1px solid rgba($ui-accent, 0.15);
  user-select: none;
  -webkit-user-select: none;
}

// Левая часть — кнопки
#title-bar-left {
  display: flex;
  align-items: stretch;
  flex-shrink: 0;

  button {
    width: 48px;
    height: 100%;
    background: transparent;
    border: none;
    border-right: 1px solid rgba($ui-accent, 0.08);
    color: rgba(255, 255, 255, 0.4);
    font-size: 14px;
    cursor: pointer;
    transition:
      background 0.2s ease,
      color 0.2s ease;
    letter-spacing: 1px;

    &:hover {
      color: #fff;
    }
  }

  // Крестик вспыхивает кровью
  #tb-close:hover {
    background: rgba($blood-red, 0.85);
    color: #fff;
  }

  #tb-minimize:hover {
    background: rgba($ui-accent, 0.12);
  }
}

// Средняя часть — draggable зона
#title-bar-drag {
  flex: 1;
  height: 100%;
  -webkit-app-region: drag;
  app-region: drag; /* stylelint-disable-line property-no-unknown */
}

// Правая часть — название + иконка
#title-bar-right {
  display: flex;
  align-items: center;
  gap: 10px;
  padding-right: 16px;
  flex-shrink: 0;
  border-left: 1px solid rgba($ui-accent, 0.08);
  padding-left: 16px;

  #tb-title {
    font-family: "Inter", sans-serif;
    font-size: 11px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.25);
  }

  #tb-icon {
    width: 20px;
    height: 20px;
    object-fit: contain;
    opacity: 0.6;
  }
}
</file>

