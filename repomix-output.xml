<file path="style.scss">
@use "styles/vars" as *;
@use "styles/animations";
@use "styles/modals";
@use "styles/system_modals";
@use "styles/menus";
@use "styles/gallery";
@use "styles/tablet";
@use "styles/mobile";
@use "styles/titlebar";

// Запрещаем выделение текста везде
* {
  -webkit-user-select: none; /* Chrome/Safari/Opera */
  -moz-user-select: none; /* Firefox */
  -ms-user-select: none; /* IE/Edge */
  user-select: none; /* Стандартный синтаксис */

  // Убиваем синюю подсветку при тапе на мобилках
  -webkit-tap-highlight-color: transparent;

  // Запрещаем всплывающее меню (Сохранить картинку / Поделиться) при долгом тапе
  -webkit-touch-callout: none;
}

// Но если у тебя вдруг будет поле ввода для имени героя, мы должны разрешить там текст!
input,
textarea {
  -webkit-user-select: auto;
  user-select: auto;
}

// Глобальная подсказка для видеокарты
#sharp-background-layers .bg-layer,
#character-layer .character-wrapper,
#dialog-box-container {
  will-change: transform, opacity;
}

// --- MIXINS ---
@mixin glass {
  background: $glass-bg;
  backdrop-filter: blur(15px);
  border: 1px solid rgba($ui-accent, 0.3);
}

// --- FONTS ---
@font-face {
  font-family: "Lora";
  src: url("/fonts/Lora-Regular.woff2") format("woff2");
}
@font-face {
  font-family: "Inter";
  src: url("/fonts/Inter24pt-Regular.woff2") format("woff2");
}

// --- RESET ---
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  outline: none;
}

body,
html {
  width: 100%;
  height: 100%;
  background-color: #000; // Черный фон ТОЛЬКО для самых краев монитора
  color: #ffffff;
  font-family: "Inter", sans-serif;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

// Контейнер, куда main.js всё рендерит
#app {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
  background: transparent; // ПРОЗРАЧНЫЙ, чтобы блюр было видно!

  // Переносим эффекты стресса с app прямо сюда (так как JS вешает классы на app)
  &.stress-med #game-viewport::before {
    opacity: 0.5;
  }

  &.stress-high {
    #game-viewport::before {
      opacity: 1;
      animation: heart-beat 1.5s infinite ease-in-out;
    }
    #dialog-box-container {
      animation: border-chaos 3s infinite ease-in-out;
      &::before {
        opacity: calc(var(--stress-val, 1) * 0.7);
      }
    }
    #name-tag {
      animation: name-pulse 2s infinite ease-in-out;
      border-color: rgba(255, 0, 0, 0.6);
      box-shadow: 0 0 10px rgba(255, 0, 0, 0.4);
    }
    #dialog-box {
      text-shadow:
        2px 0 rgba(255, 0, 0, 0.5),
        -2px 0 rgba(0, 0, 255, 0.5);
    }
    .choice-btn {
      border-color: rgba(255, 0, 0, 0.4);
      animation: button-pulse 2s infinite;
    }
  }
}

// Внутренний контейнер
#game-container {
  width: 100%;
  height: 100%;
  position: relative;
  background: transparent;
}

// --- GLOBAL BLURRED BACKGROUND (Слои, генерируемые JS) ---
#global-bg-layers {
  position: absolute;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 1;
  pointer-events: none;
  overflow: hidden;

  .bg-layer {
    position: absolute;
    top: -10%; // Большой запас, чтобы при блюре края не просвечивали
    left: -10%;
    width: 120%;
    height: 120%;
    background-size: cover;
    background-position: center;
    filter: blur(40px) brightness(0.3); // Усилили блюр, чтобы было красивее
    opacity: 0;
    transition: opacity 1s ease-in-out;
    // Убрали transform и will-change, он статичен
    &.active {
      opacity: 1;
    }
  }
}

// --- GAME VIEWPORT (Соблюдаем 16:9) ---
#game-viewport {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  height: 100%;
  overflow: hidden;
  aspect-ratio: 16 / 9;
  width: 100vw;
  max-width: calc(100vh * (16 / 9));
  max-height: 100vh;
  z-index: 10;
  pointer-events: none;
  box-shadow: 0 0 100px 20px rgba(0, 0, 0, 0.95);
  background-color: #000;

  &::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 100;
    background: radial-gradient(
      circle,
      transparent 40%,
      rgba(0, 0, 0, 0.4) 70%,
      $blood-red 100%
    );
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
  }

  &::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 99;
    background: radial-gradient(
      circle,
      transparent 70%,
      rgba(0, 0, 0, 0.5) 100%
    );
    box-shadow: inset 0 0 120px rgba(0, 0, 0, 0.8);
  }
}

// --- СЛОИ ИГРОВОГО МИРА ---
#sharp-background-layers {
  position: absolute;
  inset: 0;
  z-index: 5;
  will-change: transform;
}

#bg-1,
#bg-2 {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-size: cover;
  background-position: center;
  opacity: 0;
  transition: opacity 1s ease-in-out;
  will-change: transform;
  &.active {
    opacity: 1;
  }
}

#character-layer {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 10;
}

.character-wrapper {
  position: absolute;
  bottom: 0;
  height: 95%;
  aspect-ratio: 1216 / 832;

  // Жестко фиксируем якорь по центру навсегда
  left: 50%;

  // Анимируем через независимое свойство translate (параллакс в transform не пострадает!)
  transition: translate 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  will-change: translate;

  &.pos-center {
    translate: -50% 0;
  }

  &.pos-left {
    translate: calc(-50% - 25vw) 0; // Центр минус четверть экрана
  }

  &.pos-right {
    translate: calc(-50% + 25vw) 0; // Центр плюс четверть экрана
  }
}

.character-sprite {
  width: 100%;
  height: 100%;
  object-fit: contain;
  transform-origin: bottom center;
}

#interaction-layer {
  position: absolute;
  inset: 0;
  z-index: 50;
  pointer-events: none;
}

body.ui-hidden .interact-point {
  display: none !important;
}

// --- ЭФФЕКТЫ ---
#darkness-layer {
  position: absolute;
  inset: 0;
  z-index: 50;
  background: #000;
  opacity: 0;
  transition: opacity 0.5s ease-in-out;
  pointer-events: none;
}

#noise-layer {
  position: absolute;
  inset: 0;
  z-index: 51;
  overflow: hidden;
  pointer-events: none;
  opacity: 0;
  &::before {
    content: "";
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background-image: url("/bg/common/noise.webp");
    background-repeat: repeat;
    background-size: 128px;
    opacity: 0.15;
    animation: normal-grain 0.2s steps(4) infinite;
  }
}

.version-watermark {
  position: absolute;
  bottom: 0;
  right: 0;
  z-index: 1000;
  padding: 40px 30px 10px 50px;
  background: radial-gradient(
    100% 100% at 100% 100%,
    rgba(0, 0, 0, 0.8) 0%,
    rgba(0, 0, 0, 0) 100%
  );
  color: rgba(255, 255, 255, 0.5);
  font-family: "Inter", sans-serif;
  font-size: 13px; // ← фиксированный, не clamp
  letter-spacing: 1px;
  pointer-events: none;
  user-select: none;
  @media (max-width: 1024px) {
    // убираем bottom: 85px — пусть будет bottom: 0 как на ПК
    font-size: 10px;
    letter-spacing: 0.5px;
    padding: 30px 15px 8px 40px; // чуть компактнее padding
    // background и всё остальное — наследуется от десктопа
  }
}

// --- UI CONTAINER ---
#game-ui {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  height: 100%;
  aspect-ratio: 16 / 9;
  width: 100vw;
  max-width: calc(100vh * (16 / 9));
  max-height: 100vh;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  padding: 50px;
  pointer-events: none;
}

// --- DIALOGUE UI ---
#dialog-wrapper {
  position: relative;
  width: 90%;
  max-width: 1100px;
  display: flex;
  flex-direction: column;
  pointer-events: auto;
  margin-bottom: 20px;
  margin-top: 40px;
  z-index: 110;
  height: 260px;
  min-height: 250px;
  max-height: 260px;
  overflow: visible;
  --speaker-glow: rgba(0, 0, 0, 0);
}

@property --speaker-glow {
  syntax: "<color>";
  inherits: true;
  initial-value: rgba(0, 0, 0, 0);
}

#dialog-bg-color {
  position: absolute;
  inset: 0;
  z-index: -1;
  background: linear-gradient(
    120deg,
    rgba(10, 10, 10, 0.95) 0%,
    var(--speaker-glow) 50%,
    rgba(10, 10, 10, 0.95) 100%
  );
  background-size: 200% 200%;
  animation: shimmer-dialog 4s ease-in-out infinite;
}

#name-tag {
  position: absolute;
  top: -40px;
  left: 0;
  height: 40px;
  width: 40%;
  min-width: 300px;
  z-index: 10;
  display: flex;
  align-items: center;
  padding: 0 40px;
  background: rgba(15, 15, 15, 0.95);
  border: 1px solid rgba($ui-accent, 0.4);
  border-bottom: none;
  font-size: 18px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 4px;
  color: $ui-accent;
  clip-path: polygon(0 0, 92% 0, 100% 100%, 0% 100%);
  opacity: 0;
  transform: translateY(10px);
  transition:
    opacity 0.3s ease,
    transform 0.3s ease,
    color 0.3s ease,
    border-color 0.3s ease;
  pointer-events: none;

  &.active {
    opacity: 1;
    transform: translateY(0);
  }
}

#dialog-box-container {
  @include glass;
  position: relative;
  padding: 40px 60px;
  height: 100%;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: space-between;

  &::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 6px;
    height: 100%;
    background: var(--strip-color, #{$ui-accent});
    z-index: 2;
    pointer-events: none;
  }

  &::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(
        45deg,
        transparent 48%,
        rgba(255, 255, 255, 0.05) 49%,
        rgba(255, 255, 255, 0.05) 51%,
        transparent 52%
      ),
      linear-gradient(
        -70deg,
        transparent 30%,
        rgba(255, 0, 0, 0.1) 31%,
        rgba(255, 0, 0, 0.1) 33%,
        transparent 34%
      ),
      linear-gradient(
        120deg,
        transparent 60%,
        rgba(255, 255, 255, 0.08) 61%,
        transparent 62%
      );
    background-size:
      200px 200px,
      150px 300px,
      180px 250px;
    background-position:
      20% 30%,
      70% 10%,
      50% 80%;
    opacity: 0;
    pointer-events: none;
    z-index: 1;
    transition: opacity 0.5s ease;
  }

  #strip-fill {
    position: absolute;
    top: 0;
    left: 0;
    width: 6px;
    height: 0%;
    z-index: 3;
    background: var(--strip-fill-color, #{$ui-accent});
    transition: height 0.55s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;

    &.instant {
      transition: none !important;
    }
  }

  &.shaking {
    animation: heavy-shiver 0.15s ease-in-out;
    --strip-color: #ff4d4d;
  }
}

/* --- КНОПКА ЗАКРЫТИЯ ДИАЛОГА --- */
#dialog-hide-btn {
  position: absolute;
  top: 10px;
  right: 10px;
  width: 34px;
  height: 34px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(255, 255, 255, 0.18);
  border-radius: 10px;
  background: rgba(15, 20, 28, 0.72);
  backdrop-filter: blur(10px);
  color: rgba(255, 255, 255, 0.82);
  font-size: 20px;
  line-height: 1;
  cursor: pointer;
  z-index: 5;
  transition:
    transform 0.18s ease,
    background 0.18s ease,
    border-color 0.18s ease,
    color 0.18s ease,
    opacity 0.18s ease;
}

#dialog-hide-btn:hover {
  transform: scale(1.06);
  background: rgba(30, 38, 52, 0.92);
  border-color: rgba(255, 255, 255, 0.28);
  color: #ffffff;
}

#dialog-hide-btn:active {
  transform: scale(0.96);
}

#dialog-hide-btn:focus-visible {
  outline: none;
  box-shadow: 0 0 0 2px rgba(180, 220, 255, 0.35);
}

#dialog-box {
  font-family: "Lora", serif;
  font-size: 26px;
  color: #fdfdfd;
  line-height: 1.6;
  word-break: normal;
  overflow-wrap: normal;
  white-space: pre-wrap;
  flex-grow: 1;
  overflow: hidden;
  margin-bottom: 15px;

  &::after {
    content: "▼";
    display: inline-block;
    margin-left: 10px;
    color: $ui-accent;
    font-size: 20px;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  &.waiting::after {
    opacity: 1;
    animation: pulse-ctc-inline 1s infinite alternate ease-in-out;
  }
}

// --- CHOICE BUTTONS ---
#choice-container {
  position: fixed;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15px;
  width: 100%;
  max-width: 600px;
  z-index: 120;
  pointer-events: auto;
}

.choice-wrapper {
  width: 100%;
  position: relative;
  display: flex;
  justify-content: center;
  margin-bottom: 0;

  .choice-btn {
    width: 100%;
    padding: 22px 30px;
    @include glass;
    color: #fff;
    font-size: 20px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    position: relative; // Важно, чтобы быть над плашкой
    z-index: 2; // Кнопка всегда сверху

    &.selected {
      // Убрали :hover, оставили только .selected, как мы обсуждали
      background: rgba($ui-accent, 0.2);
      border-color: #fff;
      transform: scale(1.03);
      outline: none; // Убираем синюю обводку фокуса
    }

    &.invalid-click {
      animation: invalid-shake 0.4s ease;
      border-color: $blood-red !important;
    }
  }

  .choice-info {
    position: absolute;
    // Привязываем к правому краю
    right: 0;
    top: 50%;
    // Спрятана под кнопкой (сдвинута влево)
    transform: translateY(-50%) translateX(-20px) scale(0.9);
    opacity: 0;

    background: rgba(15, 15, 15, 0.95);
    border: 1px solid #444;
    padding: 8px 15px;
    font-size: 13px;
    white-space: nowrap;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    pointer-events: none;
    z-index: 1; // Под кнопкой

    &.met {
      border-color: #4caf50;
      color: #4caf50;
    }

    &.unmet {
      border-color: $blood-red;
      color: $blood-red;
    }
  }

  // МАГИЯ ВЫЕЗДА:
  // Когда кнопка получает класс .selected (от клавиатуры или мыши)
  // соседняя плашка choice-info выезжает вправо
  .choice-btn.selected ~ .choice-info {
    opacity: 1;
    // Выезжает вправо из-под кнопки (100% ширины плашки + 15px отступ)
    transform: translateY(-50%) translateX(calc(100% + 15px)) scale(1);
  }
}

// --- INTERACTION POINTS ---
.interact-point {
  position: absolute;
  pointer-events: auto;
  cursor: pointer;
  display: flex;
  flex-direction: column;
  align-items: center;
  transform: translate(-50%, -50%); // Точное центрирование по координатам x/y
  transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);

  .icon {
    font-size: 24px;
    filter: drop-shadow(0 0 8px rgba($ui-accent, 0.6));
    transition: transform 0.2s ease;

    // Если захотите вставить картинки вместо текста
    img {
      width: 40px;
      height: 40px;
      opacity: 0.8;
    }
  }

  // Дефолтная "взрослая" точка интереса (пульсирующий кружок)
  .dot-indicator {
    width: 16px;
    height: 16px;
    border: 2px solid #fff;
    border-radius: 50%;
    background: rgba($ui-accent, 0.4);
    box-shadow: 0 0 10px rgba($ui-accent, 0.8);
    animation: pulse-ctc-inline 1.5s infinite alternate ease-in-out;
  }

  .label {
    margin-top: 8px;
    opacity: 0.8; // Всегда чуть виден
    background: rgba(10, 10, 12, 0.9);
    color: #eee;
    padding: 6px 12px;
    font-size: 13px;
    font-family: "Inter", sans-serif;
    letter-spacing: 1px;
    text-transform: uppercase;
    border: 1px solid rgba($ui-accent, 0.3);
    border-radius: 2px;
    transition: all 0.2s ease;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
  }

  &:hover {
    transform: translate(-50%, -50%) scale(1.1); // Кнопка слегка увеличивается при наведении

    .icon {
      transform: translateY(-3px);
      filter: drop-shadow(0 0 12px $ui-accent);
      img {
        opacity: 1;
      }
    }

    .label {
      opacity: 1;
      border-color: $ui-accent;
      color: #fff;
      box-shadow: 0 0 15px rgba($ui-accent, 0.4);
    }
  }
}

// --- NOTIFICATIONS ---
#notification-container {
  position: absolute;
  top: 20px;
  right: 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  z-index: 9999;
}

.toast {
  background: rgba(15, 15, 15, 0.95);
  border-left: 4px solid;
  padding: 15px 25px;
  color: #fff;
  transform: translateX(100%);
  transition: 0.3s;

  &.show {
    transform: translateX(0);
  }
  &.error {
    border-color: $blood-red;
  }
  &.success {
    border-color: #4dff4d;
  }
  &.info {
    border-color: $ui-accent;
  }
}

// --- DIALOG FOOTER ---
#dialog-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: auto;
  padding-top: 10px;
  border-top: 1px solid rgba($ui-accent, 0.15);
  gap: 15px; // Расстояние между кнопками
}

.dialog-footer-btn {
  background: transparent;
  border: none;
  color: rgba(255, 255, 255, 0.5);
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 2px;
  cursor: pointer;
  padding: 5px 10px;
  transition: all 0.2s ease;

  &:hover {
    color: $ui-accent;
    text-shadow: 0 0 8px rgba($history-cyan, 0.6);
  }
  &::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0%;
    height: 1px;
    background: $ui-accent;
    transition: width 0.3s ease;
    box-shadow: 0 0 5px $ui-accent;
  }

  &:hover::after {
    width: 100%;
  }
}

// --- TEXT EFFECTS ---
.glitch-char {
  color: $history-red !important;
  text-shadow: 0 0 8px rgba($history-red, 0.8);
  font-family: monospace;
}

#vignette-layer {
  position: absolute;
  inset: 0; // То же самое, что top:0; left:0; right:0; bottom:0;
  z-index: 105; // Внутри game-viewport фоны имеют z-index: 10, а UI-слои 100. 105 перекроет персонажей!
  pointer-events: none;

  // Здесь вся магия:
  // До 30% от центра - абсолютная прозрачность (видно лицо)
  // На 70% уже начинается кромешная тьма
  background: radial-gradient(circle, transparent 30%, #000 70%);
  opacity: 0;
}

/* Полностью прозрачный режим для CG-сцен */
#dialog-wrapper.transparent-mode {
  #dialog-bg-color {
    background: transparent !important;
    animation: none !important;
  }

  #dialog-box-container {
    /* МАЙ: Плавный градиент от черного к прозрачному! */
    /* Текст внизу будет читаться идеально, а пикантные детали сверху не перекроются */
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.9) 0%,
      /* Темный низ под текстом */ rgba(0, 0, 0, 0.5) 60%,
      /* Полупрозрачная середина */ transparent 100%
        /* Полностью прозрачный верх */
    ) !important;

    backdrop-filter: none !important;
    border: none !important;
    box-shadow: none !important;

    &::before {
      display: none !important; /* Убираем блики */
    }
  }

  #name-tag {
    background: transparent !important;
    border: none !important;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 1) !important; // Тень для читаемости имени
  }

  #dialog-box {
    text-shadow:
      1px 1px 3px rgba(0, 0, 0, 1),
      0 0 8px rgba(0, 0, 0, 0.8) !important; // Тень для самого текста
  }

  .sl-slot-btn .delete-save-btn {
    top: 10px;
    right: 10px;
  }

  #confirm-backdrop #confirm-box {
    padding: 25px 40px;
  }
}

// === КНОПКИ ПОДДЕРЖКИ В ТИТРАХ ===
.credits-support-buttons {
  display: flex;
  gap: 30px;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 40px;

  a.support-btn {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 15px 30px;
    font-family: "Inter", sans-serif;
    font-size: 1.2rem;
    font-weight: bold;
    text-transform: uppercase;
    text-decoration: none;
    color: #fff;
    border-radius: 5px;
    transition: all 0.3s ease;

    // БАЗОВОЕ СОСТОЯНИЕ (Вариант А: Тёмные, стелс)
    background: rgba(0, 0, 0, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow: none;

    img {
      transition: all 0.3s ease;
      opacity: 0.8; // Чуть приглушаем иконку до ховера
    }

    // BOOSTY (Вспыхивает оранжевым при наведении)
    &.boosty {
      @media (hover: hover) and (pointer: fine) {
        &:hover {
          background: linear-gradient(135deg, #f15f2c 0%, #e23b24 100%);
          border-color: transparent;
          transform: scale(1.05);
          box-shadow: 0 0 25px rgba(241, 95, 44, 0.6);
          img {
            opacity: 1;
          }
        }
      }
      &:active {
        transform: scale(0.95);
      }
    }

    // PATREON (Вспыхивает коралловым при наведении)
    &.patreon {
      @media (hover: hover) and (pointer: fine) {
        &:hover {
          background: linear-gradient(135deg, #ff424d, #d1363f);
          border-color: transparent;
          transform: scale(1.05);
          box-shadow: 0 0 25px rgba(255, 66, 77, 0.6);
          img {
            opacity: 1;
          }
        }
      }
      &:active {
        transform: scale(0.95);
      }
    }
  }
}

// === МАЙ: Прибиваем надпись к полу в титрах ===
.credits-continue-hint {
  position: fixed;
  bottom: 4vh; /* Отступ снизу (4% от высоты экрана) */
  left: 50%;
  transform: translateX(-50%); /* Идеальное центрирование */
  width: 100%;
  z-index: 10;

  font-size: 1rem;
  color: #666;
  font-weight: 300;
  text-align: center;
  font-family: Arial, sans-serif;
  animation: pulseOpacity 2s infinite ease-in-out;

  // Логика переключения Клик/Касание
  .mobile-hint {
    display: none;
  }
  .desktop-hint {
    display: inline;
  }

  @media (pointer: coarse) {
    .desktop-hint {
      display: none;
    }
    .mobile-hint {
      display: inline;
    }
  }
}

// === ГЛОБАЛЬНЫЕ КЛАССЫ ДЛЯ ПЕРЕКЛЮЧЕНИЯ ПОДСКАЗОК ===
// По умолчанию (на ПК) показываем "desktop-hint", прячем "mobile-hint"
.mobile-hint {
  display: none !important;
}
.desktop-hint {
  display: inline-block !important;
}

// На мобилках и планшетах (сенсорный экран) меняем их местами
@media (pointer: coarse) {
  .mobile-hint {
    display: inline-block !important;
  }
  .desktop-hint {
    display: none !important;
  }
}
