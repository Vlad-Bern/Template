{
  "name": "sota",
  "type": "module",
  "main": "index.html",
  "window": {
    "width": 1280,
    "height": 720,
    "min_width": 800,
    "min_height": 600,
    "fullscreen": true,
    "frame": true,
    "resizable": true,
    "icon": "icons/icon.png"
  },
  "devDependencies": {
    "nw-builder": "^4.11.0",
    "sass": "^1.97.3",
    "sharp": "^0.34.5",
    "vite": "^7.3.1"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:nw": "nw-builder --version sdk --mode build --glob ./dist/**",
    "build:android": "vite build && npx cap sync android && npx cap open android",
    "compress:video": "ffmpeg -i public/bg/common/menu_bg.webm -vf scale=-1:720 -c:v libvpx-vp9 -crf 30 -b:v 0 -an public/bg_mobile/common/menu_bg.webm"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0"
  }
}
